FROM python:3.12-slim

WORKDIR /app

# Copy requirements first for layer caching
COPY agent/requirements.txt agent/requirements.txt
RUN pip install --no-cache-dir -r agent/requirements.txt

# Copy agent source
COPY agent/ agent/

# Create shared-volume directory structure
RUN mkdir -p /app/shared-volume/codex-tasks/state/governance

EXPOSE 40006

ENV PYTHONUNBUFFERED=1

CMD ["python", "-m", "agent.governance.server"]
